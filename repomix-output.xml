	result, err := RunBacktest(context.Background(), bars, strat, 10_000)
	if err != nil {
		t.Fatalf("RunBacktest: %v", err)
	}
	if len(result.EquityCurve) != len(bars) {
		t.Fatalf("equity curve len %d, want %d", len(result.EquityCurve), len(bars))

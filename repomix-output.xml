<file path="docker-compose.yml">
services:
  timescale:
    image: timescale/timescaledb:latest-pg16
    container_name: oalpha-timescale
    environment:
      POSTGRES_USER: oalpha
      POSTGRES_PASSWORD: dev
      POSTGRES_DB: oalpha
    ports:
      - "5432:5432"
    volumes:
      - timescale_data:/var/lib/postgresql/data
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U oalpha -d oalpha"]
      interval: 5s
      timeout: 5s
      retries: 10

  redis:
    image: redis:7-alpine
    container_name: oalpha-redis
    ports:
      - "6379:6379"
    healthcheck:
      test: ["CMD", "redis-cli", "ping"]
      interval: 5s
      timeout: 3s
      retries: 10

  api:
    build:
      context: .
      dockerfile: backend/Dockerfile
      target: api
    container_name: oalpha-api
    env_file:
      - .env
    environment:
      DATABASE_URL: postgres://oalpha:dev@timescale:5432/oalpha?sslmode=disable
      REDIS_URL: redis://redis:6379
      MIGRATIONS_PATH: file:///migrations
      HTTP_ADDR: ":8080"
    ports:
      - "8080:8080"
    volumes:
      - ./migrations:/migrations:ro
    depends_on:
      timescale:
        condition: service_healthy
      redis:
        condition: service_healthy

  ingest:
    build:
      context: .
      dockerfile: backend/Dockerfile
      target: ingest
    container_name: oalpha-ingest
    env_file:
      - .env
    environment:
      DATABASE_URL: postgres://oalpha:dev@timescale:5432/oalpha?sslmode=disable
      MIGRATIONS_PATH: file:///migrations
      INGEST_SYMBOLS: AAPL
      INGEST_INTERVAL: 1h
      INGEST_LOOKBACK: 17520h
    volumes:
      - ./migrations:/migrations:ro
    depends_on:
      timescale:
        condition: service_healthy

  frontend:
    build:
      context: ./frontend
      dockerfile: Dockerfile
    container_name: oalpha-frontend
    environment:
      NEXT_PUBLIC_API_URL: http://localhost:8080
    ports:
      - "3000:3000"
    depends_on:
      - api

volumes:
  timescale_data:
</file>

<file path="Makefile">
.PHONY: help up down logs db-shell migrate test-backend run-api run-ingest

help:
	@echo "O(Alpha) dev commands:"
	@echo "  make up            - start all Docker services"
	@echo "  make down          - stop services"
	@echo "  make logs          - tail compose logs"
	@echo "  make db-shell      - psql into TimescaleDB"
	@echo "  make migrate       - run migrations locally"
	@echo "  make test-backend  - go test ./..."
	@echo "  make run-api       - run API locally"
	@echo "  make run-ingest    - run ingest locally"

up:
	docker compose up -d --build

down:
	docker compose down

logs:
	docker compose logs -f

db-shell:
	docker compose exec timescale psql -U oalpha -d oalpha

migrate:
	@if [ -f .env ]; then include .env; export; fi
	cd backend && MIGRATIONS_PATH=file://../migrations go run ./cmd/migrate

test-backend:
	cd backend && go test ./...

run-api:
	cd backend && MIGRATIONS_PATH=file://../migrations go run ./cmd/api

run-ingest:
	cd backend && MIGRATIONS_PATH=file://../migrations go run ./cmd/ingest
</file>

<file path="README.md">
# O(Alpha)
Quant research and paper-trading platform with a Go backend and Next.js frontend.

## Architecture
- Frontend: Next.js (React/TypeScript)
- Backend: Go (Gin) API + ingest service
- Data: PostgreSQL with TimescaleDB
- Cache/Queue: Redis
- Orchestration: Docker Compose

## Tech Stack
- Go 1.23
- Gin, zerolog, golang-migrate
- PostgreSQL + TimescaleDB
- Next.js + TypeScript

## Getting Started
### Prerequisites
- Docker and Docker Compose
- Alpaca API Keys (paper trading)

### Quick Start
1) Copy `.env.example` to `.env` and set values:
   - `ALPACA_API_KEY`
   - `ALPACA_API_SECRET`
   - `DATABASE_URL` (optional if using the compose defaults)

2) Build and run:
```
docker compose up --build
```

3) Ingest data:
```
docker compose up ingest
```

4) Verify data (example):
```
psql "postgres://oalpha:dev@localhost:5432/oalpha" -f scripts/verify_data.sql
```

## Development Notes
- Database migrations are run automatically on API and ingest startup.
- Use `INGEST_SYMBOLS`, `INGEST_INTERVAL`, and `INGEST_LOOKBACK` to control ingest.

Project maintained by Tan Jia Jun and Zhao Shi Zhen.
</file>


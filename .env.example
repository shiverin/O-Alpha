# ============================================
# ENVIRONMENT CONFIGURATION GUIDE
# ============================================
#
# LOCAL DEVELOPMENT (VS Code):
#   Copy .env.local → .env
#   Run: go run ./cmd/api/main.go
#   Run: npm run dev
#   Uses: Supabase database
#
# DOCKER DEPLOYMENT:
#   Copy .env.docker → .env
#   Run: docker-compose up
#   Uses: Local TimescaleDB in container
#
# ============================================

# Alpaca API Keys (Get from https://app.alpaca.markets/paper/dashboard/overview)
ALPACA_API_KEY=your_key_id
ALPACA_API_SECRET=your_secret_key
ALPACA_DATA_URL=https://data.alpaca.markets

# DATABASE: Choose based on your deployment
# LOCAL: DATABASE_URL=postgres://oalpha:dev@localhost:5432/oalpha?sslmode=disable
# SUPABASE: DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres?sslmode=require
DATABASE_URL=postgres://oalpha:dev@localhost:5432/oalpha?sslmode=disable

# Redis (local default or change for your setup)
REDIS_URL=redis://localhost:6379

# Migrations path
MIGRATIONS_PATH=file://migrations

# HTTP Server address
HTTP_ADDR=:8080
JWT_SECRET=change-me-in-production
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://[::1]:3000

# Market data ingestion
INGEST_SYMBOLS=VOO,AAPL,ADBE,ADP,AMAT,AMD,AMGN,AMZN,AVGO,BKNG,CMCSA,COST,CSCO,DIA,GILD,GOOGL,INTC,INTU,ISRG,IWM,LRCX,MDLZ,META,MSFT,NFLX,NVDA,PEP,QCOM,QQQ,SBUX,SMH,SPY,TSLA,TXN,VTI,XLB,XLE,XLF,XLI,XLK,XLP,XLU,XLV,XLY,HON,ABBV,ABT,ACN,GE,KO,SCHW,AMT,AXP,BA,BAC,BLK,BMY,C,CAT,CI,COP,CRM,CVS,CVX,DE,DIS,ELV,GS,HD,IBM,JNJ,JPM,LIN,LLY,LOW,MA,MCD,MDT,MO,MRK,NEE,NKE,NOW,ORCL,PFE,PG,PLD,PM,RTX,SO,SYK,T,TMO,UNH,UPS,USB,V,VZ,WMT,XOM
INGEST_INTERVAL=1Day
INGEST_LOOKBACK=100000h
INGEST_FORCE_BACKFILL=false
INGEST_RUN_ONCE=false

# Frontend API URL (change for production)
NEXT_PUBLIC_API_URL=http://localhost:8080
